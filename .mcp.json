{
  "mcpServers": {
    "sequential-thinking": {
      "command": "sequential-thinking-mcp"
    },
    "firebase": {
      "command": "firebase",
      "args": [
        "experimental:mcp"
      ],
      "env": {
        "FIREBASE_PROJECT_ID": "deepread-app"
      }
    },
    "vercel": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-vercel"
      ],
      "env": {
        "VERCEL_TOKEN": "YOUR_VERCEL_TOKEN_HERE"
      }
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_PERSONAL_ACCESS_TOKEN_HERE"
      }
    }
  }
}
